# Copy to .env.local for overrides (optional)

# Local dev (default in .env.development): Vite proxy /api → http://localhost:8080/api/*
# VITE_API_BASE_URL=/api

# Direct local backend (no proxy)
# VITE_API_BASE_URL=http://localhost:8080

# Render production (set in Render Static Site env vars before build)
# VITE_API_BASE_URL=https://cloudberries-candidate-match.onrender.com
